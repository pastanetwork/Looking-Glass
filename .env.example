# ============================================================
#  Variables d'environnement
#  Copiez ce fichier en .env et adaptez les valeurs.
# ============================================================

# --- Général ---
# Laissez False. `python lg.py dev` force le mode développement en local
# (reload, bypass Turnstile) ; `python lg.py run` est toujours en production.
DEV=False

# Chemin du fichier de config JSON structuré (optionnel, monté en volume Docker).
LG_CONFIG_FILE=/config/config.json

# --- Serveur HTTP ---
LG_HOST=0.0.0.0
LG_PORT=8080
LG_WORKERS=4

# URL publique canonique (SEO, balises des templates). Laisser vide en local.
LG_PUBLIC_URL=

# Hôtes de confiance autorisés à réécrire l'IP cliente via X-Real-IP (le reverse proxy nginx).
TRUSTED_PROXY_HOSTS=127.0.0.1

# Noms d'hôte acceptés dans l'en-tête Host (séparés par des virgules ; motif « *.domaine »
# autorisé). Vide = tout accepter. Les hôtes loopback restent toujours acceptés.
ALLOWED_HOSTS=

# Origines autorisées en CORS (séparées par des virgules, ex. https://exemple.com).
# Vide = same-origin uniquement (l'API n'est consommée que par le frontend du LG).
# Les autres réglages CORS (méthodes, en-têtes, max-age) se règlent dans le fichier JSON.
CORS_ALLOW_ORIGIN=

# Mettre à True si le site est servi derrière Cloudflare. L'application lit alors
# l'IP réelle du visiteur dans l'en-tête CF-Connecting-IP (vérifié contre les plages
# Cloudflare, récupérées au démarrage). Sans ça, l'IP vue serait celle d'un proxy
# Cloudflare. Rien à configurer côté nginx.
CLOUDFLARE_ENABLED=False

# --- Redis (interne à l'image Docker, éphémère) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optionnel. Généré automatiquement par l'entrypoint Docker si laissé vide.
# En dev local, laissez vide si votre Redis n'a pas de mot de passe.
REDIS_PASSWORD=

# --- Sécurité ---
# Optionnel. Sel de hachage SHA-256 des IP sources. Auto-généré puis persisté dans
# data/.ip_hash_salt si absent. Renseignez-le pour un sel stable et explicite.
IP_HASH_SALT=

# Cloudflare Turnstile, obligatoire en production.
# Clés gratuites : https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Bypass de Turnstile en développement (n'a d'effet que si DEV=True ;
# `python lg.py dev` l'active automatiquement, inutile de le mettre à True ici).
TURNSTILE_DEV_BYPASS=False

# --- Plafonds de concurrence (anti-abus) ---
# Nombre maximum de commandes simultanées, tous clients confondus.
GLOBAL_COMMAND_CAP=8
# Nombre maximum de commandes simultanées par IP cliente.
PER_IP_COMMAND_CAP=2

# --- Speedtest (test de débit, désactivé par défaut) ---
# Feature opt-in. Les valeurs ci-dessous sont des garde-fous sûrs : si vous
# l'activez, le speedtest ne pourra pas faire déraper une facturation transit
# au 95e centile ni votre volume mensuel.
SPEEDTEST_ENABLED=True
# Volume total servi par jour, tous clients confondus. Une fois atteint, le
# speedtest est coupé jusqu'au lendemain — c'est LE garde-fou : il borne le
# temps d'antenne du speedtest. 0 = illimité (déconseillé en production).
# 805306368000 = 750 Gio/jour (~5 h d'antenne/mois sur une liaison 10G).
SPEEDTEST_DAILY_BYTE_BUDGET=805306368000
# Volume par IP et par jour. 0 = illimité. 32212254720 = 30 Gio/jour.
SPEEDTEST_PER_IP_BYTE_BUDGET=32212254720
# Débit maximum par connexion, en kilo-octets/s. 0 = non bridé : le client voit
# le vrai débit du lien (le budget journalier reste le garde-fou).
SPEEDTEST_MAX_KBPS=0
# Connexions speedtest simultanées, tous clients confondus. Un test CLI en ouvre 4
# en parallèle : prévoir au moins 4, idéalement un multiple pour plusieurs tests.
SPEEDTEST_CONCURRENCY=16

# --- Divers ---
# Rétention du journal des requêtes, en jours.
QUERY_LOG_RETENTION_DAYS=90
# Langue par défaut de l'interface (fr, en).
DEFAULT_LANGUAGE=fr
